# ===========================================
# Leaf PHP Application Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# Never commit .env to version control!

# -------------------------------------------
# Application Settings
# -------------------------------------------
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_NAME="Leaf PHP Application"
APP_TIMEZONE=UTC

# -------------------------------------------
# Server Configuration
# -------------------------------------------
# Railway automatically sets PORT, leave empty for local dev
PORT=

# -------------------------------------------
# Database Configuration
# -------------------------------------------
# Supported: mysql, pgsql, sqlite
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=leaf_app
DB_USERNAME=root
DB_PASSWORD=secret

# Railway Database (auto-injected when you add a database)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# -------------------------------------------
# Session Configuration
# -------------------------------------------
# Driver de sesiones: redis, file, database
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_NAME=leaf_session
SESSION_PATH=/tmp/sessions
# Cookie segura (requiere HTTPS)
SESSION_SECURE_COOKIE=true

# -------------------------------------------
# Cache Configuration
# -------------------------------------------
CACHE_DRIVER=file
CACHE_PATH=./cache
CACHE_PREFIX=leaf_

# -------------------------------------------
# Logging Configuration
# -------------------------------------------
LOG_DRIVER=file
LOG_LEVEL=debug
LOG_PATH=./storage/logs
LOG_FILE=app.log

# -------------------------------------------
# Security
# -------------------------------------------
# Generate with: openssl rand -hex 32
APP_KEY=
CSRF_ENABLED=true

# -------------------------------------------
# Mail Configuration (Optional)
# -------------------------------------------
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

# -------------------------------------------
# Queue Configuration (Optional)
# -------------------------------------------
QUEUE_DRIVER=sync
QUEUE_CONNECTION=database

# -------------------------------------------
# Redis Configuration (Optional)
# -------------------------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DATABASE=0

# Railway Redis (auto-injected when you add a Redis service)
# REDIS_URL=redis://user:pass@host:6379

# -------------------------------------------
# File Upload Configuration
# -------------------------------------------
MAX_FILE_UPLOAD_SIZE=10485760
UPLOAD_PATH=./storage/uploads

# -------------------------------------------
# CORS Configuration (Optional)
# -------------------------------------------
CORS_ENABLED=false
CORS_ORIGINS=*
CORS_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_HEADERS=Content-Type,Authorization
