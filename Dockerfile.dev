# ===========================================
# Leaf PHP - Development Dockerfile
# Includes Xdebug and development tools
# ===========================================

FROM php:8.2-cli

# Set environment variables
ENV DEBIAN_FRONTEND=noninteractive
ENV APP_ENV=development
ENV APP_DEBUG=true
ENV XDEBUG_MODE=debug,develop

# Install system dependencies
RUN apt-get update && apt-get install -y \
    git \
    curl \
    vim \
    nano \
    libpng-dev \
    libonig-dev \
    libxml2-dev \
    libzip-dev \
    libicu-dev \
    unzip \
    default-mysql-client \
    postgresql-client \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Install PHP extensions
RUN docker-php-ext-install \
    pdo \
    pdo_mysql \
    pdo_pgsql \
    mbstring \
    exif \
    pcntl \
    bcmath \
    zip \
    intl

# Install Xdebug
RUN pecl install xdebug \
    && docker-php-ext-enable xdebug \
    && echo "xdebug.client_host=host.docker.internal" >> /usr/local/etc/php/conf.d/docker-php-ext-xdebug.ini \
    && echo "xdebug.client_port=9003" >> /usr/local/etc/php/conf.d/docker-php-ext-xdebug.ini \
    && echo "xdebug.start_with=1" >> /usr/local/etc/php/conf.d/docker-php-ext-xdebug.ini \
    && echo "xdebug.log=/tmp/xdebug.log" >> /usr/local/etc/php/conf.d/docker-php-ext-xdebug.ini

# Install Composer
COPY --from=composer:latest /usr/bin/composer /usr/bin/composer

# Create working directory
WORKDIR /app

# Copy application files
COPY . /app

# Install dependencies (including dev)
RUN composer install --no-interaction --no-progress

# Create necessary directories with proper permissions
RUN mkdir -p storage/logs storage/uploads cache views && \
    chmod -R 777 storage cache

# Expose port
EXPOSE 8000

# Expose Xdebug port
EXPOSE 9003

# Default command
CMD ["php", "-S", "0.0.0.0:8000", "-t", "public"]
